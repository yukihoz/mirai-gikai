#--- Common ---
# npx supabase statusで確認できる情報を設定してください
SUPABASE_URL=http://127.0.0.1:54421
# `npx supabase status` の "Secret" を設定してください
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54421
# `npx supabase status` の "Publishable" を設定してください
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Web側のキャッシュを無効化するためのシークレットキー
REVALIDATE_SECRET=your-secret-key-here
# Vercel AI GatewayのAPIキーを設定してください
AI_GATEWAY_API_KEY=
# AdminサーバーのURL（web/admin両方で使用）
ADMIN_URL=http://localhost:3001

#--- Web ---
# Basic認証をONにする場合は設定してください
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
# Langfuse設定（プロンプト管理・LLM監視）
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# AI Chatの日次コストリミット（USD）- ユーザー単位（旧名 CHAT_DAILY_COST_LIMIT_USD もフォールバックとして有効）
CHAT_DAILY_USER_COST_LIMIT_USD=
# AI Chatの日次コストリミット（USD）- システム全体
CHAT_DAILY_TOTAL_COST_LIMIT_USD=
# AI Chatの月間コストリミット（USD）- システム全体
CHAT_MONTHLY_TOTAL_COST_LIMIT_USD=

# --- Admin ---
# WebサーバーのURLを設定してください
NEXT_PUBLIC_WEB_URL=http://localhost:3000
# --- Site Configuration ---
# デフォルト値は「みらい議会」と「国会」です。独自自治体向けに書き換えてください。
NEXT_PUBLIC_SITE_TITLE="みらい議会@中央区（仮）"
NEXT_PUBLIC_SITE_SHORT_NAME="みらい議会"
NEXT_PUBLIC_ASSEMBLY_NAME="区議会"
NEXT_PUBLIC_TEAM_NAME="チームみらい"

# MCPサーバー（/api/mcp）へのBearer認証トークン。mirai-gikai-content のエージェント等から接続するときに使用する。
ADMIN_MCP_TOKEN=

# --- Supabase Auth (Google OAuth) ---
# Google OAuth用の設定（本番・staging環境で必要）
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
# OAuthコールバックURL（config.tomlのadditional_redirect_urlsで参照、ADMIN_URL + /api/auth/callback）
ADMIN_AUTH_CALLBACK_URL=http://localhost:3001/api/auth/callback
